{
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
  "extends": ["ultracite/biome/core", "ultracite/biome/next"],
  "files": {
    "includes": ["!!**/.agents"]
  },
  "overrides": [
    {
      "includes": ["apps/web/public/r/**/*.json", "packages/ui/registry.json"],
      "formatter": { "enabled": false },
      "linter": { "enabled": false },
      "assist": { "enabled": false }
    },
    {
      // Static marketing/chart SVG exports — not hand-edited React components
      "includes": ["apps/web/public/**/*.svg"],
      "formatter": { "enabled": false },
      "linter": { "enabled": false },
      "assist": { "enabled": false }
    },
    {
      // Generated shadcn registry sources (registry:build); not hand-edited
      "includes": ["packages/ui/registry/**"],
      "formatter": { "enabled": false },
      "linter": { "enabled": false },
      "assist": { "enabled": false }
    },
    {
      // Allow barrel files for library exports - standard pattern for component libraries
      "includes": [
        "packages/ui/src/**/index.ts",
        "packages/ui/src/charts/line-chart.tsx",
        "packages/ui/src/charts/area-chart.tsx",
        "packages/ui/src/charts/scatter-chart.tsx"
      ],
      "linter": {
        "rules": {
          "performance": {
            "noBarrelFile": "off"
          }
        }
      }
    },
    {
      // Allow namespace imports for shadcn/ui components - standard pattern
      "includes": ["apps/web/components/ui/**"],
      "linter": {
        "rules": {
          "performance": {
            "noNamespaceImport": "off"
          }
        }
      }
    },
    {
      // Studio shadcn/ui primitives (base-nova) — same lint posture as apps/web
      "includes": ["packages/studio/src/ui/**"],
      "linter": {
        "rules": {
          "a11y": {
            "noLabelWithoutControl": "off",
            "noNoninteractiveElementInteractions": "off",
            "useKeyWithClickEvents": "off",
            "useSemanticElements": "off"
          },
          "performance": {
            "noNamespaceImport": "off"
          },
          "style": {
            "noNestedTernary": "off"
          },
          "suspicious": {
            "noArrayIndexKey": "off"
          }
        }
      }
    },
    {
      "includes": ["packages/icons/src/index.ts"],
      "linter": {
        "rules": {
          "performance": {
            "noBarrelFile": "off"
          }
        }
      }
    },
    {
      // Chart components have inherent complexity due to handling multiple configurations
      // (stacked/grouped, horizontal/vertical, multi-series, tooltips, animations)
      "includes": [
        "packages/ui/src/charts/bar-chart.tsx",
        "packages/ui/src/charts/bar.tsx"
      ],
      "linter": {
        "rules": {
          "complexity": {
            "noExcessiveCognitiveComplexity": "off"
          }
        }
      }
    }
  ]
}
