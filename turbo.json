{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "globalEnv": [
    "BKLIT_API_KEY",
    "BKLIT_PROJECT_ID",
    "OPENPANEL_CLIENT_ID",
    "OPENPANEL_CLIENT_SECRET",
    "CLIENT_ID",
    "CLIENT_SECRET",
    "TAURI_ENV_PLATFORM",
    "TAURI_ENV_DEBUG"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [
        ".next/**",
        "!.next/cache/**",
        ".source/**",
        "dist/**",
        "src-tauri/target/release/bundle/**"
      ]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "test": {
      "dependsOn": ["^test"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
