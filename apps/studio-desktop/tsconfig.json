{
  "extends": "@bklitui/typescript-config/react-library.json",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "noEmit": true,
    "declaration": false,
    "declarationMap": false,
    "baseUrl": ".",
    "paths": {
      "@desktop/*": ["./src/*"],
      "@/lib/utils": ["../../packages/ui/src/lib/utils.ts"],
      "@/*": ["../../packages/studio/src/*"],
      "@bklitui/studio": ["../../packages/studio/src/index.ts"],
      "@bklitui/ui/lib/utils": ["../../packages/ui/src/lib/utils.ts"],
      "@bklitui/ui/charts": ["../../packages/ui/src/charts/index.ts"],
      "@/components/shimmering-text": [
        "../../apps/web/components/shimmering-text.tsx"
      ]
    },
    "types": ["vite/client"]
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist", "src-tauri"]
}
